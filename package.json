{
  "name": "seekapi",
  "version": "0.1.0",
  "description": "Pure API gateway for search and agent-facing service providers",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/app/server.ts",
    "build": "tsc",
    "start": "node dist/app/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "zod": "^3.24.2",
    "drizzle-orm": "^0.38.4",
    "pg": "^8.13.1",
    "ioredis": "^5.4.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.57.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-metrics": "^1.30.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5",
    "eslint": "^9.19.0",
    "@eslint/js": "^9.19.0",
    "typescript-eslint": "^8.22.0",
    "drizzle-kit": "^0.30.4",
    "@types/node": "^22.12.0",
    "@types/pg": "^8.11.11"
  }
}
